# backend/.gitignore

# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.development
.env.test
.env.production

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
.nyc_output/

# Uploads
uploads/*
!uploads/.gitkeep

# Misc
.DS_Store
*.pem
.vscode/
.idea/

# Docker
.docker/