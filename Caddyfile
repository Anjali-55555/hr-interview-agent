# Caddyfile for HTTPS support
{
    auto_https disable_redirects
    local_certs
}

# Main site - handles both frontend and API
localhost {
    tls internal
    
  # API requests - proxy to backend (keep /api in path)
    handle /api/* {
        reverse_proxy app:5000
    }
    
    # Everything else goes to frontend
    handle {
        reverse_proxy frontend:80
    }
}